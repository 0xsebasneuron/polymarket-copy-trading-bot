# Copy to ".env" in the project root (same folder you run the app from).
# Never commit a real ".env" with secrets.

# Required for CLOB bundle execution (unless stored in SQLite instead)
PM_PRIVATE_KEY=
# Funder / vault for CLOB. Optional for all signature types:
# - PM_SIG_TYPE=0 → defaults to signer EOA
# - PM_SIG_TYPE=1 or 2 → defaults to Polymarket CREATE2 Safe derived from PM_PRIVATE_KEY


# Optional: CLOB signature type — 0 = EOA, 1 = POLY_PROXY, 2 = Gnosis Safe (Polymarket relayer).
# PM_SIG_TYPE=0

# Optional: simulate bundle execution — live order book still used; no CLOB post_order (1/true/yes/on).
# PM_SIMULATE=1

# Optional: Polygon RPC for allowance / approval checks (defaults to a public endpoint).
# PM_RPC_URL=https://polygon-bor-rpc.publicnode.com

# Builder API (Polymarket) — required only for on-chain approvals via relayer (PM_SIG_TYPE 1 or 2).
# Same credentials as the Rust app / CLOB init.
# PM_BUILDER_KEY=
# PM_BUILDER_SECRET=
# PM_BUILDER_PASSPHRASE=
